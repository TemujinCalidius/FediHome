# ============================================
# FediHome — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values.
# Most settings are configured via the setup wizard at /setup
#
# Required values are uncommented. Optional ones are commented out.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/fedihome

# --- Site URL ---
# Your public domain (used for ActivityPub, RSS, links)
SITE_URL=http://localhost:3000

# --- Admin Secret ---
# Generated automatically during setup. Used to log into the admin panel.
# Keep this safe — it's your master password.
ADMIN_SECRET=

# --- Fediverse Identity ---
# Your handle will be @FEDI_HANDLE@FEDI_DOMAIN
FEDI_HANDLE=me
FEDI_DOMAIN=example.com

# --- Site Info ---
# SITE_NAME=My FediHome
# AUTHOR_NAME=Your Name
# AUTHOR_TAGLINE=
# AUTHOR_BIO=
# CONTACT_EMAIL=
# SITE_DESCRIPTION=A personal space on the Fediverse.
# ACTOR_SUMMARY=A personal blog on the Fediverse, powered by FediHome.

# --- Optional: Bluesky Crossposting ---
# Get an app password at: https://bsky.app/settings/app-passwords
# BLUESKY_HANDLE=yourhandle.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Optional: Threads Crossposting ---
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=

# --- Optional: Tinylytics Analytics ---
# Privacy-focused analytics. Get an API key at: https://tinylytics.app
# TINYLYTICS_API_KEY=tly-fa-xxxx
# TINYLYTICS_SITE_ID=

# --- Optional: Email (for account recovery + DayOne journal) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=
# DAYONE_EMAIL=
