# ============================================
# FediHome — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values.
# Most settings are configured via the setup wizard at /setup
#
# Required values are uncommented. Optional ones are commented out.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/fedihome

# --- Site URL ---
# Your public domain (used for ActivityPub, RSS, links)
SITE_URL=http://localhost:3000

# --- Optional: App listen port ---
# Port the app binds to (npm start / pm2). Defaults to 3000. Set this if
# port 3000 is already taken on the host. NOTE: the listen port is separate
# from SITE_URL above — if you change it, make sure SITE_URL still points at
# your real public origin, or federation/CSRF will break.
# PORT=3000
# Docker only: host port published by docker-compose (maps to container :3000).
# FEDIHOME_PORT=3000

# --- Admin Secret ---
# Generated automatically during setup. Used to log into the admin panel.
# Keep this safe — it's your master password.
ADMIN_SECRET=

# --- Optional: Admin session lifetime ---
# How many days an admin login stays valid before it must sign in again
# (default 30). Sessions are individually revocable from the /admin/sessions
# page, so a lost/stolen device can be signed out without rotating ADMIN_SECRET.
# ADMIN_SESSION_TTL_DAYS=30

# --- Optional: App (OAuth) token lifetime ---
# How many days a bearer token issued to a connected app (via the OAuth flow)
# stays valid. Unset (or <= 0) → tokens don't expire (long-lived + revocable from
# /admin/apps), which is the default. Set a number to auto-expire app tokens;
# expired tokens are rejected and swept automatically.
# APP_TOKEN_TTL_DAYS=90

# --- Optional: First-run setup token ---
# Protects the one-time setup wizard on a fresh, publicly-exposed deploy: until
# ADMIN_SECRET is set, completing /setup requires this token, so a stranger
# can't claim your site first. If you don't set it here, FediHome generates one
# on first run and prints it to the server console. (install.sh sets
# ADMIN_SECRET for you, so its installs skip the wizard entirely.)
# SETUP_TOKEN=

# --- Fediverse Identity ---
# Your handle will be @FEDI_HANDLE@FEDI_DOMAIN
FEDI_HANDLE=me
FEDI_DOMAIN=example.com

# --- Site Info ---
# SITE_NAME=My FediHome
# AUTHOR_NAME=Your Name
# AUTHOR_TAGLINE=
# AUTHOR_BIO=
# CONTACT_EMAIL=
# SITE_DESCRIPTION=A personal space on the Fediverse.
# ACTOR_SUMMARY=A personal blog on the Fediverse, powered by FediHome.

# --- Optional: Public landing / showcase mode ---
# Turns the homepage into a project-style landing page (hero + feature
# highlights + CTAs) instead of the personal blog intro. Off by default.
# Used by the public demo to present an "About FediHome" homepage.
# LANDING_MODE=true
# LANDING_HEADLINE=Your home on the open social web
# LANDING_SUBHEAD=FediHome is a self-hosted personal site that speaks ActivityPub — your blog, photos, videos and a live Fediverse feed, all owned by you.
# REPO_URL=https://github.com/TemujinCalidius/fedihome

# --- Optional: Public read-only Fediverse feed ---
# Exposes /fediverse — a login-free, read-only view of the accounts you follow
# (no like/boost/reply, no admin). Great for a demo. Off by default.
# PUBLIC_FEED=true
# PUBLIC_FEED_TITLE=The Fediverse feed

# --- Optional: Hide your social graph ---
# When set, /ap/followers and /ap/following still report their counts but no
# longer list who follows you / who you follow (Mastodon's "hide social graph").
# Off by default.
# HIDE_SOCIAL_GRAPH=true

# --- Optional: Navigation visibility ---
# Hide nav sections you don't use. Each section shows unless set to "false".
# NAV_SHOW_JOURNAL=false
# NAV_SHOW_ARTICLES=false
# NAV_SHOW_PHOTOGRAPHY=false
# NAV_SHOW_VIDEOS=false
# NAV_SHOW_AUDIO=false
# NAV_SHOW_ABOUT=false

# --- Optional: Footer extras ---
# The copyright (AUTHOR_NAME), Fediverse handle and CONTACT_EMAIL show
# automatically. These optional extras only appear when set:
# WEBRING_URL=https://your-webring.example
# WEBRING_LABEL=Webring
# FOOTER_BADGE_SRC=https://example.com/badge.png
# FOOTER_BADGE_HREF=https://example.com
# FOOTER_BADGE_ALT=Some badge
# Optional "Support the project" link — a themed ♥ link on the landing page
# (LANDING_MODE) and in the footer. Point it at your GitHub Sponsors / Ko-fi /
# Liberapay / etc. Unset → no donation link shown anywhere.
# FUNDING_URL=https://github.com/sponsors/yourname
# FUNDING_LABEL=Support FediHome

# --- Optional: Web Push (PWA phone notifications) ---
# Lets you install the site to your phone's home screen and receive push
# notifications for likes/boosts/replies/follows/DMs/comments — even when closed.
# Dormant until these are set. Generate a keypair with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# --- Optional: Bluesky Crossposting ---
# Get an app password at: https://bsky.app/settings/app-passwords
# BLUESKY_HANDLE=yourhandle.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Optional: Threads Crossposting ---
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=

# --- Optional: Tinylytics Analytics ---
# Privacy-focused analytics. Create a site at https://tinylytics.app for a site
# code + API key. TINYLYTICS_SITE_ID drives BOTH the on-page tracking embed (which
# collects pageviews) and the server-side API reads; TINYLYTICS_API_KEY is
# additionally required for the in-app analytics dashboard. Set BOTH for the full
# experience — with only the key, nothing is tracked and the dashboard stays empty.
# TINYLYTICS_API_KEY=tly-fa-xxxx
# TINYLYTICS_SITE_ID=
# Only set this if your embed's site code differs from the API site id:
# TINYLYTICS_EMBED_ID=

# --- Optional: Email (for account recovery + DayOne journal) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=
# DAYONE_EMAIL=
