generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url supplied via prisma.config.ts (Prisma 7 hard-errors P1012 if present here)
}

// === Blog Content ===

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String?
  content     String   // markdown
  contentHtml String?  // rendered HTML cache
  excerpt     String?
  category    String   @default("note") // note, article, journal
  tags        String[]
  coverImage  String?
  photos         String[] // array of image paths for photo posts
  photoCaptions  String[] // parallel array of captions/alt text
  videos             String[] // array of canonical PeerTube URLs (https://makertube.net/w/...)
  videoTitles        String[] // parallel array of video titles
  videoThumbnails    String[] // parallel array of thumbnail URLs (may be empty strings)
  audioPaths         String[] // array of /uploads/audio/... mp3 paths
  audioTitles        String[] // parallel array of audio titles
  audioCovers        String[] // parallel array of audio cover image URLs (may be empty strings)
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  // Set when a post is scheduled for future publish: created with published=false
  // and scheduledFor/publishedAt in the future; the scheduler flips it live at the
  // time. A plain draft leaves this null (the scheduler ignores it). (#183)
  scheduledFor DateTime?
  updatedAt   DateTime @updatedAt

  // ActivityPub
  apId        String?  @unique // e.g. https://example.com/post/my-post

  // Bluesky crosspost
  blueskyUri  String?  // at:// URI returned from crosspost

  // Threads crosspost id. Written by the shared publisher; doubles as the
  // idempotency marker so a delivery retry can't double-post to Threads. (#195)
  threadsPostId String?

  // Set when a scheduled post's delivery attempt (federation + crossposts)
  // completed. A claimed (published=true) scheduled post with federatedAt null
  // crashed mid-delivery and is retried once by the scheduler. (#195)
  federatedAt DateTime?

  // Fedi interaction counts (cached)
  likeCount   Int      @default(0)
  boostCount  Int      @default(0)

  // Bluesky interaction counts (cached, updated on poll)
  bskyLikeCount   Int  @default(0)
  bskyRepostCount Int  @default(0)

  // Guest comments
  guestComments GuestComment[]

  // Bluesky replies
  blueskyReplies BlueskyReply[]

  // Author follow-up threading: a Post can be a reply to another of our own Posts.
  inReplyToPostId String?
  inReplyTo       Post?   @relation("PostFollowUps", fields: [inReplyToPostId], references: [id])
  followUps       Post[]  @relation("PostFollowUps")

  @@index([publishedAt])
  @@index([category])
  @@index([inReplyToPostId])
  @@index([scheduledFor])
}

// === Bluesky Replies ===

model BlueskyReply {
  id           String   @id @default(cuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id])
  blueskyUri   String   @unique // the reply's AT URI
  authorDid    String
  authorHandle String
  displayName  String?
  avatarUrl    String?
  content      String
  createdAt    DateTime
  fetchedAt    DateTime @default(now())

  @@index([postId])
}

// Per-actor Bluesky interactions on our posts (likes, reposts, mentions,
// quotes, follows), ingested from app.bsky.notification.listNotifications into
// the notification bell + push. Replies stay in BlueskyReply (the post page
// already renders them). Deduped by the notification's own at:// uri, since
// listNotifications is at-least-once. (#134)
model BlueskyInteraction {
  id           String   @id @default(cuid())
  type         String   // "like" | "repost" | "mention" | "quote" | "follow"
  notifUri     String   @unique // the notification's own at:// uri — dedup key
  notifCid     String
  authorDid    String
  authorHandle String
  displayName  String?
  avatarUrl    String?
  subjectUri   String?  // our Post.blueskyUri (like/repost/quote); null for mention/follow
  postUri      String?  // the actor's own bsky post uri (mention/quote) for deep-linking
  content      String?  // record.text (mention/quote)
  reason       String   // raw notification.reason (forward-compat / debug)
  createdAt    DateTime // record.createdAt, falling back to indexedAt
  fetchedAt    DateTime @default(now())

  @@index([type])
  @@index([subjectUri])
  @@index([createdAt])
}

// === Photography ===

model Photo {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String?
  caption     String?
  imagePath   String   // /uploads/2026/03/photo.jpg
  thumbPath   String?  // smaller version for grid
  category    String   @default("general") // wildlife, macro, landscape, street, general
  exifData    Json?    // { camera, lens, aperture, shutter, iso, focalLength }
  tags        String[]
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())

  // Intrinsic dimensions for masonry layout
  width       Int?
  height      Int?

  // Hero slider on /photography
  hero        Boolean  @default(false)
  heroOrder   Int?

  // ActivityPub
  apId        String?  @unique

  // Fedi interaction counts
  likeCount   Int      @default(0)
  boostCount  Int      @default(0)

  // Guest comments
  guestComments GuestComment[]

  @@index([publishedAt])
  @@index([category])
}

// === Videos (PeerTube embeds) ===

model Video {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String?
  description  String?
  embedUrl     String
  embedHost    String
  embedId      String
  iframeSrc    String
  thumbnailUrl String?
  duration     Int?
  category     String   @default("general")
  tags         String[]
  published    Boolean  @default(true)
  publishedAt  DateTime @default(now())
  hero         Boolean  @default(false)
  heroOrder    Int?
  apId         String?  @unique
  likeCount    Int      @default(0)
  boostCount   Int      @default(0)

  @@index([publishedAt])
  @@index([category])
}

// === Audio (uploaded MP3s) ===

model Audio {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String?
  description  String?
  mp3Path      String
  durationSec  Int?
  fileSize     Int?
  coverImage   String?
  category     String   @default("general")
  tags         String[]
  published    Boolean  @default(true)
  publishedAt  DateTime @default(now())
  hero         Boolean  @default(false)
  heroOrder    Int?
  apId         String?  @unique
  likeCount    Int      @default(0)
  boostCount   Int      @default(0)

  @@index([publishedAt])
  @@index([category])
}

// === Guest Comments ===

model GuestComment {
  id          String   @id @default(cuid())
  guestName   String
  guestEmail  String?
  content     String
  ipHash      String   // hashed IP for rate limiting
  status      String   @default("pending") // pending, approved, rejected
  federated   Boolean  @default(false) // has been published to Fediverse

  // Can be on a Post or Photo
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id])
  photoId     String?
  photo       Photo?   @relation(fields: [photoId], references: [id])

  createdAt   DateTime @default(now())

  @@index([status])
  @@index([postId])
  @@index([photoId])
}

// === Fediverse ===

model FediFollower {
  id        String   @id @default(cuid())
  actorUri  String   @unique // e.g. https://mastodon.social/users/someone
  inbox     String
  sharedInbox String?
  username  String
  domain    String
  displayName String?
  avatarUrl String?
  accepted  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model FediFollowing {
  id        String   @id @default(cuid())
  actorUri  String   @unique
  inbox     String
  username  String
  domain    String
  displayName String?
  avatarUrl String?
  createdAt DateTime @default(now())
}

// Actors the owner has blocked (#180). `block` records a row here (in addition to
// its unfollow + Block delivery + content purge) so the block list is listable
// and reversible; `unblock` deletes the row + delivers Undo Block. `inbox` is
// cached so unblock can deliver without re-resolving.
model BlockedActor {
  id          String   @id @default(cuid())
  actorUri    String   @unique
  handle      String?  // @user@domain
  displayName String?
  avatarUrl   String?
  inbox       String?
  createdAt   DateTime @default(now())
}

model BlueskyFollower {
  id          String   @id @default(cuid())
  did         String   @unique
  handle      String
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  fetchedAt   DateTime @default(now())
}

model BlueskyFollowing {
  id          String   @id @default(cuid())
  did         String   @unique
  handle      String
  displayName String?
  avatarUrl   String?
  followUri   String?
  createdAt   DateTime @default(now())
  fetchedAt   DateTime @default(now())
}

model FediPost {
  id          String   @id @default(cuid())
  actorUri    String
  apId        String   @unique
  content     String
  contentHtml String?
  mediaUrls   String[]
  mediaTypes  String[] // parallel to mediaUrls: "image" or "video"
  username    String
  domain      String
  displayName String?
  avatarUrl   String?
  publishedAt DateTime
  // Set when a remote Update (edit) was applied to this stored post (#205).
  // Null = never edited since we stored it.
  editedAt    DateTime?
  createdAt   DateTime @default(now())

  isOutgoing  Boolean  @default(false) // true for posts/replies WE sent

  // Boost/repost tracking
  boostedBy     String?  // actorUri of the person who boosted this into our feed
  boostedByName String?  // display name of the booster

  // Conversation threading
  inReplyTo      String?  // AP ID of parent post
  conversationId String?  // groups posts into threads

  // Link preview embed
  embedUrl         String?
  embedTitle       String?
  embedDescription String?
  embedImage       String?  // local proxied path to og:image
  embedSiteName    String?

  // Cached interaction counts fetched on-demand from the remote AP object.
  // Null means "never fetched"; null after fetch means the remote hides that
  // collection (Mastodon authenticated-fetch quirks).
  likeCount       Int?
  boostCount      Int?
  replyCount      Int?
  countsFetchedAt DateTime?

  // Whether the site owner has liked / boosted this post — drives the feed's
  // like/boost button state so it survives a reload.
  likedByMe   Boolean @default(false)
  boostedByMe Boolean @default(false)

  @@index([publishedAt])
  @@index([conversationId])
  @@index([inReplyTo])
}

model FediInteraction {
  id        String   @id @default(cuid())
  type      String   // like, boost, reply
  actorUri  String
  targetApId String  // the AP ID of the post/photo being interacted with
  sourceApId String? // the interacting activity's own apId (a reply Note's id); dedups redelivered replies. Null for like/boost. NOT @unique on purpose — `prisma db push` (the update path) refuses to add a unique constraint without --accept-data-loss, so dedup is enforced in app code (handleNote) instead.
  content   String?  // for replies
  username  String
  domain    String
  displayName String?
  avatarUrl String?
  createdAt DateTime @default(now())

  @@index([targetApId])
  @@index([type])
  @@index([sourceApId])
}

// === Auth (for Micropub) ===

model AuthToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  label      String    // e.g. "iA Writer", "Quill", "FediHome for macOS"
  scope      String    @default("create update delete media")
  clientId   String?   // the OAuth client that minted this; null for hand-issued Micropub tokens
  createdVia String    @default("micropub") // "micropub" | "oauth"
  expiresAt  DateTime? // null = no expiry (revocable); set for expiring app tokens
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

// Per-request audit trail for connected apps (#158): which token/app hit which
// endpoint, and when. Best-effort + coarse (method + path), pruned to a rolling
// window. Logs NON-GET (write/action) bearer requests only — read polls aren't
// recorded, to keep the signal high and the table bounded.
model AppTokenUsage {
  id       String   @id @default(cuid())
  tokenId  String?  // AuthToken.id at time of use (null if since revoked)
  clientId String?  // OAuth client id, if any
  label    String   // token label (e.g. "FediHome for macOS")
  scope    String   // token scope at time of use
  method   String   // HTTP method
  path     String   // request path
  at       DateTime @default(now())

  @@index([at])
}

// Short-lived, single-use OAuth 2.0 / IndieAuth authorization codes. Issued by
// /api/oauth/authorize, exchanged ONCE (PKCE-verified) at /api/oauth/token, then
// deleted. Bound to the client + redirect + scope + PKCE challenge that created it.
model AuthorizationCode {
  id            String   @id @default(cuid())
  codeHash      String   @unique // SHA-256 of the authorization code
  clientId      String
  redirectUri   String
  scope         String
  codeChallenge String            // PKCE S256 challenge (base64url)
  expiresAt     DateTime          // short TTL (~60s)
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}

// Persisted admin login sessions. The cookie is "<id>.<HMAC(ADMIN_SECRET, id)>";
// `id` is the random 32-hex session id (the cookie's first segment). Persisting
// it makes sessions individually revocable — verifyAdmin checks the row exists
// and is unexpired, so deleting a row invalidates that cookie on next use. (#14)
model AdminSession {
  id         String   @id          // = cookie session id (32-hex); not a cuid
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime?
  userAgent  String?               // for the sessions UI ("Chrome on macOS")

  @@index([expiresAt])
}

// === Direct Messages ===

model DirectMessage {
  id              String   @id @default(cuid())
  source          String   // "fedi" or "bluesky"

  senderUri       String   // actorUri (fedi) or DID (bluesky)
  senderHandle    String   // @user@domain (fedi) or handle.bsky.social
  senderName      String?
  senderAvatar    String?

  content         String
  contentHtml     String?
  apId            String?  @unique
  bskyConvoId     String?
  bskyMessageId   String?  @unique

  conversationKey String   // "fedi:{actorUri}" or "bsky:{did}"
  isOutgoing      Boolean  @default(false)

  // Delivery audit for outgoing messages. Both null = not yet attempted.
  // deliveredAt set = remote inbox accepted (2xx). deliveryError set = failed.
  deliveredAt     DateTime?
  deliveryError   String?

  createdAt       DateTime
  fetchedAt       DateTime @default(now())

  @@index([conversationKey])
  @@index([source])
  @@index([createdAt])
}

// Server-side read tracking for DM conversations. Replaces the previous
// client-localStorage approach so unread state syncs across devices and
// survives a storage clear.
model DmConversationRead {
  conversationKey String   @id
  lastReadAt      DateTime
  updatedAt       DateTime @updatedAt
}

// === ActivityPub Keys ===

model ActorKeys {
  id         String @id @default("main")
  publicKey  String
  privateKey String
}

// === Web Push (PWA notifications) ===
// One row per browser/device push endpoint the owner has enabled. Single-user
// site, so every subscription belongs to the admin. Dead endpoints (410/404 on
// send) are pruned automatically by the push dispatcher.
model PushSubscription {
  id         String   @id @default(cuid())
  endpoint   String   @unique
  p256dh     String   // client public key (base64url) for payload encryption
  auth       String   // client auth secret (base64url)
  userAgent  String?  // best-effort, to tell devices apart in the UI
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  failures   Int      @default(0)
}

// === Site Settings (created by setup wizard) ===

model SiteSettings {
  id            String   @id @default("main")
  setupDone     Boolean  @default(false)
  siteName      String?
  authorName    String?
  authorBio     String?
  authorTagline String?
  contactEmail  String?
  verifiedEmail String?
  accentColor   String?  @default("#3b82f6")
  // Runtime-editable profile (#201) — overlaid on the site.config.ts env
  // defaults by getRuntimeProfile(). Null = use the env/default value.
  actorSummary  String?
  avatarPath    String?
  bannerPath    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// === Key-value settings (notification read state, etc.) ===

model FailedCrosspost {
  id          String    @id @default(cuid())
  postId      String
  platform    String // "bluesky" | "threads"
  payload     String // JSON of the crosspost args, re-sent verbatim on retry (text, url, images?, video?, replyTo?)
  attempts    Int       @default(0)
  nextRetryAt DateTime
  lastError   String?
  failedAt    DateTime? // set when we give up (terminal); null = still retrying
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([postId, platform])
  @@index([nextRetryAt])
}

model FailedDelivery {
  id          String    @id @default(cuid())
  inbox       String
  activityId  String
  activity    String // the full activity JSON, re-sent verbatim so the id is stable (remote servers dedupe)
  attempts    Int       @default(0)
  nextRetryAt DateTime
  lastError   String?
  failedAt    DateTime? // set when we give up (terminal); null = still retrying
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([activityId, inbox])
  @@index([nextRetryAt])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model MaintenanceItem {
  id          String   @id @default(cuid())
  kind        String   // "update" | "security" | "release-note"
  packageName String
  current     String?
  latest      String?
  severity    String?
  title       String
  description String?
  url         String?
  dismissed   Boolean  @default(false)
  applied     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([kind, packageName, latest])
}
