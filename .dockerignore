# Keep the build context clean + reproducible. Everything below is recreated
# inside the image (npm ci → node_modules, prisma generate → src/generated,
# next build → .next), so shipping the host copies would only bloat the context
# and risk overwriting the container's Linux deps with host (macOS) binaries.
node_modules
.next
out
.git
src/generated
.env
.env.local
.env.*.local
# User uploads are bind-mounted at runtime (see docker-compose.yml), so baking a
# copy into the image would only bloat every layer — and would shadow-mask the
# mount's contents while it did (#308).
public/uploads
*.log
.DS_Store
.claude
coverage
